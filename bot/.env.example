# bot/.env.example
# Copy this to .env for local development
# On Render, set these as Environment Variables in the dashboard

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_ID=your_telegram_user_id_here

# Firebase
FIREBASE_PROJECT_ID=your_firebase_project_id

# For LOCAL dev: path to your downloaded service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# For RENDER (production): paste the entire service account JSON as a single-line string
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
